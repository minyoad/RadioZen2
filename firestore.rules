rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Stations: Publicly readable, admin writable
    match /stations/{stationId} {
      allow read: if true; // Public discovery
      
      // Admin check - for now only my placeholder admin or a specific flag
      function isAdmin() {
        return isSignedIn() && (
          request.auth.token.email == 'minyoad@gmail.com' // From runtime metadata
        );
      }

      function isValidStation(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
            && data.streamUrl is string && data.streamUrl.size() > 0 && data.streamUrl.size() <= 500;
      }

      allow create: if isAdmin() && isValidStation(request.resource.data);
      allow update: if isAdmin() && isValidStation(request.resource.data);
      allow delete: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users shouldn't be listable
      
      function isValidProfile(data) {
        return data.keys().hasAll(['name']) 
            && data.name is string && data.name.size() <= 50;
      }

      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'bio', 'avatarUrl', 'listeningMinutes', 'level', 'updatedAt']);
      
      // Favorites subcollection
      match /favorites/{favId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
